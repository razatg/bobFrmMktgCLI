# macOS
.DS_Store
**/.DS_Store

# Python
__pycache__/
*.pyc
*.pyo

# Virtual environments
venv/
.venv/
env/

# Environment variables / secrets
.env

# --- Bob Frm Mktg ---

# Local account registry and per-account configs (local state, not for sharing)
.bob/profile.json
.bob/accounts.json
.bob/accounts/

# Team sync config (./bob sync) — per-machine shared-folder path, never in the public repo
.bob/sync.json

# Raw API outputs
garf/outputs/raw/

# Processed data
data/processed/

# Wiki analyses — kept out of the PUBLIC repo. Shared with teammates via `./bob sync`
# (a shared folder, e.g. synced Dropbox — no git), never pushed to GitHub origin.
wiki/

# Operational logs — pull-log is machine-local; session-signals + backlog are shared with the
# team via `./bob sync` (a shared folder), NOT the public repo. backlog.md was previously tracked
# and is now untracked (git rm --cached) so user bug/feature quotes stay out of the public repo.
logs/pull-log.jsonl
logs/session-signals.jsonl
logs/backlog.md

# Validation runtime outputs
validation/manual/*
!validation/manual/.gitkeep
validation/reports/*
!validation/reports/.gitkeep

# google-ads mutation and log output dirs
google-ads/logs/*
google-ads/mutations/*

# AI desktop app local config dirs
.antigravitycli/
.claude/settings.local.json

# Generated by setup.sh — local launcher with hardcoded venv path
/bob
validation/
