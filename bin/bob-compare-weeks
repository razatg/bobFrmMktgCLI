#!/usr/bin/env bash
# Compare performance across two ISO calendar weeks.
# Usage: bob-compare-weeks [--week N] [--vs M] [--year YYYY] [--grain account|campaign|both]
set -euo pipefail
ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
if [ -x "$ROOT/bob" ]; then
  exec "$ROOT/bob" compare-weeks "$@"
else
  exec python3 "$ROOT/lib/datapull.py" compare-weeks "$@"
fi
